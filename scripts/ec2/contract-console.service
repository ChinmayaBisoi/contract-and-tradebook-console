[Unit]
Description=Contract and Tradebook Operations Console
After=network.target

[Service]
Type=simple
User=deploy
Group=deploy
WorkingDirectory=/opt/contract-console/current
EnvironmentFile=/etc/contract-console/env
ExecStart=/usr/bin/node /opt/contract-console/current/server.js
Restart=always
RestartSec=5
KillSignal=SIGINT
TimeoutStopSec=30

[Install]
WantedBy=multi-user.target
