generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Organisation {
  id               String             @id @default(cuid())
  name             String
  description      String?
  users            OrganisationUser[]
  invitations      Invitation[]
  uploads          Upload[]
  tradebookImports TradebookImport[]
  contracts        Contract[]
  lineItems        LineItem[]
  auditEvents      AuditEvent[]
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  @@index([name])
}

enum OrganisationUserRole {
  OWNER
  ADMIN
  MEMBER
}

enum OrganisationUserStatus {
  ACTIVE
  DISABLED
  REMOVED
}

model OrganisationUser {
  id              String                 @id @default(cuid())
  clerkUserId     String
  clerkUserName   String
  clerkUserEmail  String
  organisationId  String
  organisation    Organisation           @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role            OrganisationUserRole   @default(MEMBER)
  status          OrganisationUserStatus @default(ACTIVE)
  statusChangedAt DateTime               @default(now())
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  auditEvents     AuditEvent[]

  @@unique([clerkUserId, organisationId])
  @@index([organisationId])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
  CANCELLED
}

enum InvitationRole {
  ADMIN
  MEMBER
}

model Invitation {
  id                 String           @id @default(cuid())
  email              String
  organisationId     String
  organisation       Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  role               InvitationRole
  inviterClerkUserId String
  inviterName        String
  inviterEmail       String
  status             InvitationStatus @default(PENDING)
  expiresAt          DateTime
  createdAt          DateTime         @default(now())
  updatedAt          DateTime         @updatedAt
  auditEvents        AuditEvent[]

  @@index([email, status, createdAt])
  @@index([organisationId, status, createdAt])
}

enum UploadSourceType {
  EXCEL
  JSON
  AI_EXTRACT
}

enum UploadStatus {
  UPLOADED
  PROCESSING
  PROCESSED
  FAILED
}

enum TradebookImportStatus {
  PENDING
  MAPPED
  IMPORTED
  FAILED
}

enum ContractStatus {
  DRAFT
  FINALIZED
  ARCHIVED
}

enum AuditAction {
  CREATE
  UPDATE
  STATUS_CHANGE
  DELETE
  IMPORT
  ROLE_CHANGE
  INVITE
  ACCEPT
  DECLINE
  CANCEL
}

enum AuditEntityType {
  CONTRACT
  LINE_ITEM
  UPLOAD
  TRADEBOOK_IMPORT
  ORGANISATION_USER
  INVITATION
}

model Upload {
  id                    String           @id @default(cuid())
  organisationId        String
  organisation          Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploadedByClerkUserId String
  sourceType            UploadSourceType
  status                UploadStatus     @default(UPLOADED)
  fileName              String?
  mimeType              String?
  fileSizeBytes         Int?
  storageKey            String?
  blobUrl               String?
  checksum              String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  tradebookImport       TradebookImport?
  contracts             Contract[]
  lineItems             LineItem[]
  auditEvents           AuditEvent[]

  @@index([organisationId, createdAt])
  @@index([organisationId, status, createdAt])
  @@index([checksum])
}

model TradebookImport {
  id                    String                @id @default(cuid())
  organisationId        String
  organisation          Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploadId              String                @unique
  upload                Upload                @relation(fields: [uploadId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  status                TradebookImportStatus @default(PENDING)
  sheetNames            Json
  workbookSnapshot      Json?
  formulaSnapshot       Json?
  mappingConfig         Json?
  validationErrors      Json?
  importedContractCount Int                   @default(0)
  importedLineItemCount Int                   @default(0)
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  contracts             Contract[]
  lineItems             LineItem[]
  auditEvents           AuditEvent[]

  @@index([organisationId, createdAt])
  @@index([organisationId, status, createdAt])
}

model Contract {
  id                   String           @id @default(cuid())
  organisationId       String
  organisation         Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploadId             String?
  upload               Upload?          @relation(fields: [uploadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tradebookImportId    String?
  tradebookImport      TradebookImport? @relation(fields: [tradebookImportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  status               ContractStatus   @default(DRAFT)
  sourceType           UploadSourceType
  clientName           String
  poRefNo              String
  poDate               DateTime
  paymentTerms         String?
  deliveryTerms        String?
  fieldData            Json
  createdByClerkUserId String
  finalizedAt          DateTime?
  archivedAt           DateTime?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  lineItems            LineItem[]
  auditEvents          AuditEvent[]

  @@unique([organisationId, poRefNo])
  @@index([organisationId, status, createdAt])
  @@index([organisationId, clientName])
  @@index([uploadId])
  @@index([tradebookImportId])
}

model LineItem {
  id                String           @id @default(cuid())
  organisationId    String
  organisation      Organisation     @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  contractId        String
  contract          Contract         @relation(fields: [contractId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  uploadId          String?
  upload            Upload?          @relation(fields: [uploadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tradebookImportId String?
  tradebookImport   TradebookImport? @relation(fields: [tradebookImportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  sourceRowRef      Json?
  workbookItemId    String?
  description       String
  quantity          Decimal
  quantityUnit      String?
  unitPrice         Decimal
  pricingUnit       String?
  total             Decimal?
  sortOrder         Int              @default(0)
  createdAt         DateTime         @default(now())
  updatedAt         DateTime         @updatedAt
  auditEvents       AuditEvent[]

  @@index([organisationId, updatedAt])
  @@index([organisationId, description])
  @@index([contractId, sortOrder])
  @@index([uploadId])
  @@index([tradebookImportId])
}

model AuditEvent {
  id                 String                @id @default(cuid())
  organisationId     String
  organisation       Organisation          @relation(fields: [organisationId], references: [id], onDelete: Cascade, onUpdate: Cascade)
  actorClerkUserId   String?
  actorName          String?
  actorEmail         String?
  actorRole          OrganisationUserRole?
  action             AuditAction
  entityType         AuditEntityType
  entityId           String
  entityLabel        String?
  beforeState        Json?
  afterState         Json?
  changedFields      String[]
  metadata           Json?
  contractId         String?
  contract           Contract?             @relation(fields: [contractId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  lineItemId         String?
  lineItem           LineItem?             @relation(fields: [lineItemId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  uploadId           String?
  upload             Upload?               @relation(fields: [uploadId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  tradebookImportId  String?
  tradebookImport    TradebookImport?      @relation(fields: [tradebookImportId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  organisationUserId String?
  organisationUser   OrganisationUser?     @relation(fields: [organisationUserId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  invitationId       String?
  invitation         Invitation?           @relation(fields: [invitationId], references: [id], onDelete: SetNull, onUpdate: Cascade)
  occurredAt         DateTime              @default(now())

  @@index([organisationId, occurredAt])
  @@index([organisationId, action, occurredAt])
  @@index([organisationId, entityType, occurredAt])
  @@index([actorClerkUserId, occurredAt])
  @@index([contractId, occurredAt])
  @@index([lineItemId, occurredAt])
  @@index([uploadId, occurredAt])
  @@index([tradebookImportId, occurredAt])
  @@index([organisationUserId, occurredAt])
  @@index([invitationId, occurredAt])
}
