# Copy example env vars
# cp .env.example .env

# --- Local PostgreSQL (recommended for dev) ---
# Start: bun run db:up
# Migrate: bun run db:migrate
# DATABASE_URL=postgresql://contractview:contractview@localhost:5433/contractview_dev
# DIRECT_URL=postgresql://contractview:contractview@localhost:5433/contractview_dev

# --- Neon (staging / production) ---
# Pooled Neon connection for the application runtime.
DATABASE_URL=postgresql://<DB_OWNER>:<DB_PASS>@<ENDPOINT>.<REGION>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

# Direct Neon connection for Prisma schema and migration commands.
DIRECT_URL=postgresql://<DB_OWNER>:<DB_PASS>@<ENDPOINT>.<REGION>.aws.neon.tech/neondb?sslmode=require&channel_binding=require

NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=test-key

CLERK_SECRET_KEY=test-secret

NEXT_PUBLIC_CLERK_SIGN_IN_FORCE_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard

# debug | info | warn | error
LOG_LEVEL=debug

# UploadThing must support private file ACLs for the tradebookWorkbook route.
UPLOADTHING_TOKEN=test-token

# Use public-read on UploadThing's free tier. Production should use private (default).
UPLOADTHING_WORKBOOK_ACL=public-read

# Optional. Without this key, deterministic and manual mapping remain available.
OPENAI_API_KEY=test_api_key
OPENAI_MAPPING_MODEL=gpt-5-nano
